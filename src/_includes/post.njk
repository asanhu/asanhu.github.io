---
layout: base.njk
---
<article class="post">
  <h1>{{ title }}</h1>
  <p class="meta">
    <time datetime="{{ page.date | isoDate }}">{{ page.date | readableDate }}</time>
    {%- for tag in tags %}{% if tag != "posts" %} · <a href="/category/{{ tag }}/">{{ tag }}</a>{% endif %}{% endfor %}
  </p>
  {{ content | safe }}
</article>
