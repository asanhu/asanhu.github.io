---
layout: base.njk
pagination:
  data: collections.categories
  size: 1
  alias: category
permalink: /category/{{ category }}/
eleventyComputed:
  title: "{{ category }}"
---
<h1>{{ category }}</h1>
<ul class="post-list">
  {%- for post in collections[category] | reverse %}
  <li>
    <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
  </li>
  {%- endfor %}
</ul>
